<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve existing files and directories as-is (.php URLs stay as-is)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Optional clean URLs → PHP (query string preserved)
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L,QSA]
</IfModule>
